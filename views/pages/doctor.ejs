<div class="common-table-container row" id="page-doctor">
    <div class="col-xl-12">
        <div class="row mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <p class="title-page">
                                <%= title %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="container-table">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead class="table-dark">
                                <tr class="text-center">
                                    <th>
                                        <p>STT</p>
                                    </th>
                                    <th>
                                        <p>Tên khách hàng</p>
                                    </th>
                                    <th>
                                        <p>SĐT</p>
                                    </th>
                                    <th>
                                        <p>Địa chỉ khu vực</p>
                                    </th>
                                    <th>
                                        <p>Trạng thái</p>
                                    </th>
                                    <th>
                                        <p>Ngày tạo</p>
                                    </th>
                                    <th>
                                        <p></p>
                                    </th>

                                </tr>
                            </thead>
                            <tbody class="body-table"></tbody>
                        </table>
                    </div>
                    <nav>
                        <ul class="pagination" id="privacy-main-pager"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
<!-- modal update-->
<div class="modal common-modal doctor-update-modal" tabindex="-1" role="dialog"
    aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <p class="modal-header-title">Chi tiết yêu cầu</p>
                <button type="button" class="close btn" data-bs-dismiss="modal" aria-label="Close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4.5 4.5L19.5 19.5" stroke="#212529" stroke-width="3" stroke-linecap="round" />
                        <path d="M19.5 4.5L4.5 19.5" stroke="#212529" stroke-width="3" stroke-linecap="round" />
                    </svg>
                </button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <input type="hidden" id="seq" value="">
                    
                    <!-- Thông tin khách hàng -->
                    <div class="card border-0 bg-light rounded-4 mb-4">
                        <div class="card-body p-4">
                            <h6 class="mb-4" style="color: #565c66;"><i class="fa fa-user-circle me-2" style="color: #505050;"></i>Thông tin yêu cầu hỗ trợ</h6>
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Tên khách hàng</label>
                                    <p class=" mb-0" id="userName"></p>
                                </div>
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Số điện thoại</label>
                                    <p class=" mb-0" id="userPhone"></p>
                                </div>
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Trạng thái xử lý</label>
                                    <div id="status-container">
                                        <select class="form-select form-select-md" id="status"></select>
                                    </div>
                                </div>
                                <div class="col-12 mt-4">
                                    <label class="text-muted small d-block mb-2">Địa chỉ khu vực</label>
                                    <div class="bg-white p-3 rounded-3 border">
                                        <p class="mb-0 text-dark" id="note" style="line-height: 1.6;"></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3 d-none">
                        <div class="col-md-12">
                            <label class="mb-2 ">Phản hồi của bác sĩ:</label>
                            <textarea class="form-control rounded-3" id="noteAnswered" rows="3" placeholder="Nhập nội dung phản hồi..."></textarea>
                            <div class="err-noteAnswered text-danger small mt-1">Vui lòng nhập nội dung phản hồi.</div>
                        </div>
                    </div>

                    <!-- Danh sách hình ảnh -->
                    <div class="mb-4 d-none">
                        <h6 class=" mb-3 d-flex align-items-center" style="color: #565c66;">
                            <i class="fa fa-images me-2" style="color: #505050;"></i> Hình ảnh mô tả triệu chứng
                        </h6>
                        <div id="doctorFiles-images" class="row g-3">
                            <!-- JS render -->
                        </div>
                    </div>

                    <!-- Danh sách video -->
                    <div class="d-none">
                        <h6 class=" mb-3 d-flex align-items-center" style="color: #565c66;">
                            <i class="fa fa-video me-2" style="color: #505050;"></i> Video mô tả triệu chứng
                        </h6>
                        <div id="doctorFiles-videos" class="row g-3">
                            <!-- JS render -->
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-main">Lưu thay đổi</button>
            </div>
        </div>
    </div>
</div>
<script src="/js/page-doctor.js"></script>