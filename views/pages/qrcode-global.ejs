<% if (values.qrData) { %>
<div class="page-qrcode-update">
    <div class="row">
        <div class="col-12">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                       <div class="card-body">
                             <div class="row g-4">
                                <!-- Thông tin cơ bản -->
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm overflow-hidden">
                                        <div class="card-header bg-white py-3 border-bottom-0">
                                            <h5 class="mb-0 fw-bold d-flex align-items-center">
                                                Thông tin chung
                                            </h5>
                                        </div>
                                        <div class="card-body pt-0">
                                            <div class="row g-4">
                                                <!-- Row 1 -->
                                                <div class="col-md-6" id="blockchain-box">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-link"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Blockchain:</div>
                                                            <div class="fw-bold"><a class="link-premium" target="_blank" href="<%= values.qrData.transactionHash %>"><i class="fa fa-external-link-alt me-1"></i> Blockchain Link</a></div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-qrcode"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Mã định danh:</div>
                                                            <div class="fw-bold text-break"><%= values.qrData.requestCode %></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Row 2 -->
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-user"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Chủ sở hữu:</div>
                                                            <div class="fw-bold"><%= values.qrData.userName %></div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-home"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Tên nhà yến:</div>
                                                            <div class="fw-bold"><%= values.qrData.userHomeName %></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Row 3 -->
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-map-marker-alt"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Địa chỉ sản xuất:</div>
                                                            <div class="fw-bold"><%= values.qrData.userHomeAddress %></div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-ruler-combined"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Quy mô nhà yến:</div>
                                                            <div class="fw-bold">
                                                                <%= values.qrData.userHomeLength %>m × <%= values.qrData.userHomeWidth %>m × <%= values.qrData.userHomeFloor %> tầng
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Row 4 -->
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-thermometer-half"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Điều kiện môi trường:</div>
                                                            <div class="fw-bold"><%= values.qrData.temperature %>°C / <%= values.qrData.humidity %>%</div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-check-circle"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Trạng thái xác thực:</div>
                                                            <div class="fw-bold">
                                                                <span class="txt-status-<%= values.qrData.requestStatus.toLowerCase() %>">
                                                                    <%= values.qrData.requestStatusLabel %>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Row 5 (Lẻ) -->
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-box me-3">
                                                            <i class="fa fa-calendar-alt"></i>
                                                        </div>
                                                        <div>
                                                            <div class="text-muted small">Thời điểm khởi tạo:</div>
                                                            <div class="fw-bold">
                                                                <%= new Date(values.qrData.createdAt).toLocaleString('vi-VN') %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- video, img-->
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm overflow-hidden">
                                        <div class="card-header bg-white py-3 border-bottom-0">
                                            <h5 class="mb-0 fw-bold d-flex align-items-center">
                                                Nhật ký sơ chế & đóng gói
                                            </h5>
                                        </div>
                                        <div class="card-body p-3 pt-0" id="processing-packing-container">
                                            <div class="loading-placeholder d-flex align-items-center justify-content-center py-5 text-muted">
                                                <div class="text-center">
                                                    <div class="spinner-border text-primary mb-3" role="status"></div>
                                                    <p class="mb-0 small">Đang tải dữ liệu đa phương tiện...</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Danh sách thuốc -->
                            <div class="mt-5">
                                <div class="d-flex align-items-center mb-3">
                                    <h5 class="fw-bold mb-0">
                                        Dược phẩm đã sử dụng
                                    </h5>
                                </div>
                                <% if (values.qrData.taskMedicineList && values.qrData.taskMedicineList.length > 0) { %>
                                    <div class="table-responsive rounded shadow-sm border">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="table-light">
                                                <tr class="text-center">
                                                    <th class="py-3">Tên vật tư/thuốc</th>
                                                    <th class="py-3">Liều lượng sử dụng</th>
                                                    <th class="py-3">Thời điểm sử dụng</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% values.qrData.taskMedicineList.forEach(item => { %>
                                                    <tr class="text-center">
                                                        <td class="fw-bold text-dark"><%= item.medicineName %></td>
                                                        <td><%= item.medicineUsage %></td>
                                                        <td class="text-muted"><%= new Date(item.timestamp).toLocaleString('vi-VN') %></td>
                                                    </tr>
                                                <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                <% } else { %>
                                    <div class="alert alert-light border text-center py-4">
                                        <i class="fa fa-info-circle me-2"></i> Chưa có dữ liệu lăn thuốc/vật tư
                                    </div>
                                <% } %>
                            </div>

                            <!-- Kết quả thu hoạch -->
                            <div class="mt-5">
                                <div class="d-flex align-items-center mb-3">
                                    <h5 class="fw-bold mb-0">
                                        Nhật ký thu hoạch chi tiết
                                    </h5>
                                </div>
                                <% if (values.qrData.taskHarvestList && values.qrData.taskHarvestList.length > 0) { %>
                                    <% values.qrData.taskHarvestList.forEach(harvest => { %>
                                        <div class="card mb-4 border-0 shadow-sm">
                                            <div class="card-header text-white py-2" style="background-color: #121927b3;">
                                                Đợt <%= harvest.harvestPhase %> - Năm <%= harvest.harvestYear %>
                                            </div>
                                            <div class="card-body bg-light bg-opacity-10">
                                                <div class="row g-3">
                                                    <% harvest.harvestData.forEach(floor => { %>
                                                        <div class="col-md-4">
                                                            <div class="card border shadow-none h-100">
                                                                <div class="card-header bg-white text-primary text-center fw-bold border-bottom-0 pt-3">
                                                                    Tầng <%= floor.floor %>
                                                                </div>
                                                                <div class="card-body pt-0">
                                                                    <table class="table table-sm table-borderless mb-0 align-middle">
                                                                        <thead>
                                                                            <tr class="text-center small text-muted border-bottom">
                                                                                <th class="fw-normal py-2">Ô</th>
                                                                                <th class="fw-normal py-2">Đã thu</th>
                                                                                <th class="fw-normal py-2">Còn lại</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <% floor.floorData.forEach(cell => { %>
                                                                                <tr class="text-center border-bottom border-light last-border-0">
                                                                                    <td class="py-2 text-muted">#<%= cell.cell %></td>
                                                                                    <td class="py-2 text-success fw-bold"><%= cell.cellCollected %></td>
                                                                                    <td class="py-2 text-danger fw-bold"><%= cell.cellRemain %></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    <% }) %>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="alert alert-light border text-center py-4">
                                        <i class="fa fa-info-circle me-2"></i> Chưa có dữ liệu thu hoạch chi tiết
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<% } else { %>
<div class="alert alert-warning">
    Không tìm thấy dữ liệu QR
</div>
<% } %>
<script>
    const qrDataGlobal = <%- JSON.stringify(values.qrData) %>;
    console.log('qrDataGlobal', qrDataGlobal);
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // RENDER MEDIA (ẢNH & VIDEO)
        const container = document.getElementById('processing-packing-container');
        if (container) {
            container.innerHTML = ''; // Clear loading

            // Lấy dữ liệu file (kiểm tra parse nếu đang lưu dạng chuỗi JSON)
            let files = qrDataGlobal?.requestQrcodeFiles;
            if (typeof files === 'string') {
                try {
                    files = JSON.parse(files);
                } catch (e) {
                   console.log(e);
                }
            }

            if (Array.isArray(files) && files.length > 0) {
                //  max-height và scrollbar 
                let mediaHTML = `<div class="row g-2" style="max-height: 500px; overflow-y: auto; overflow-x: hidden;">`;

                files.forEach(file => {
                    const fullUrl = typeof CURRENT_URL !== 'undefined' ? `${CURRENT_URL}/${file.filename}` : `/${file.filename}`;

                    if (file.mimetype && file.mimetype.startsWith('video/')) {
                        // Video - Hiển thị tỷ lệ nguyên bản
                        mediaHTML += `
                            <div class="col-md-4 col-sm-6 mb-3">
                                <div class="bg-dark rounded shadow-sm overflow-hidden h-100 d-flex align-items-center">
                                    <video controls preload="metadata" class="w-100 d-block" style="max-height: 300px;">
                                        <source src="${fullUrl}" type="${file.mimetype}">
                                        Trình duyệt không hỗ trợ phát video.
                                    </video>
                                </div>
                            </div>
                        `;
                    } else if (file.mimetype && file.mimetype.startsWith('image/')) {
                        // Hình ảnh - Hiển thị tỷ lệ nguyên bản
                        mediaHTML += `
                            <div class="col-md-4 col-sm-6 mb-3">
                                <a href="${fullUrl}" target="_blank" class="d-block w-100 h-100">
                                    <img src="${fullUrl}" 
                                         class="img-fluid rounded shadow-sm w-100" 
                                         style="height: 200px; object-fit: cover;" 
                                         alt="Hình ảnh sơ chế"
                                         loading="lazy">
                                </a>
                            </div>
                        `;
                    }
                });

                mediaHTML += `</div>`;
                container.innerHTML = mediaHTML;
            } else {
                container.innerHTML = `<div class="alert alert-warning mb-0 text-center">Chưa có dữ liệu hình ảnh/video</div>`;
            }
        }

        // --- 2. ASSIGN BLOCKCHAIN LINK ---
        const blockchainBox = document.getElementById("blockchain-box");
        if (blockchainBox && (!qrDataGlobal || !qrDataGlobal.transactionHash)) {
            blockchainBox.style.display = "none";
        }
    });
</script>