<div class="common-table-container row" id="page-consignment">
      <div class="col-xl-12">
          <div class="row mb-3">
            <div class="col-12">
               <div class="card">
                  <div class="card-body">
                     <div class="d-flex justify-content-between">
                        <p class="title-page"><%= title %></p>
                     </div>
                  </div>
               </div>
            </div>
         </div>
         <div class="row">
            <div class="col-12">
               <div class="container-table">
                  <div class="table-responsive">
                     <table class="table table-striped">
                        <thead class="table-dark">
                           <tr class="text-center">
                              <th>
                                 <p>STT</p>
                              </th>
                              <th>
                                 <p>Tên/SĐT người gửi</p>
                              </th>
                               <th>
                                 <p>Tên/SĐT người nhận</p>
                              </th>
                              <th>
                                 <p>Địa chỉ cần giao</p>
                              </th>
                              <th>
                                 <p>Loại yến</p>
                              </th>
                              <th>
                                 <p>Khối lượng yến</p>
                              </th>
                               <th>
                                 <p>Trạng thái</p>
                              </th>
                              <th>
                                 <p>Ngày tạo</p>
                              </th>
                               <th>
                                
                              </th>
                           </tr>
                        </thead>
                        <tbody class="body-table"></tbody>
                     </table>
                  </div>
                  <nav>
                     <ul class="pagination" id="privacy-main-pager"></ul>
                  </nav>
               </div>
            </div>
         </div>
      </div>
   </div>
   </div>
   <!-- modal update-->
<div class="modal common-modal consignment-update-modal" tabindex="-1" role="dialog"
    aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <p class="modal-header-title">Chỉnh sửa trạng thái</p>
                <button type="button" class="close btn" data-bs-dismiss="modal" aria-label="Close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4.5 4.5L19.5 19.5" stroke="#212529" stroke-width="3" stroke-linecap="round" />
                        <path d="M19.5 4.5L4.5 19.5" stroke="#212529" stroke-width="3" stroke-linecap="round" />
                    </svg>
                </button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <input type="hidden" id="consignmentCode" value="">
                    <input type="hidden" id="userCode" value="">
                    <input type="hidden" id="consignmentStatusDb" value="">

                    <!-- Thông tin ký gửi -->
                    <div class="card border-0 bg-light rounded-4 mb-4">
                        <div class="card-body p-4">
                            <h6 class="mb-4" style="color: #565c66;"><i class="fa fa-box me-2" style="color: #505050;"></i>Thông tin ký gửi yến</h6>
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Tên người gửi</label>
                                    <p class="mb-0" id="senderName"></p>
                                </div>
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Số điện thoại</label>
                                    <p class="mb-0" id="senderPhone"></p>
                                </div>
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Trạng thái hiện tại</label>
                                    <div>
                                        <select class="form-select form-select-md" id="consignmentStatus"></select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Loại yến</label>
                                    <p class="fw-bold mb-0 text-primary" id="nestTypeLabel"></p>
                                </div>
                                <div class="col-md-4">
                                    <label class="text-muted small d-block mb-1">Khối lượng (g)</label>
                                    <p class="fw-bold mb-0 text-danger" id="nestQuantity"></p>
                                </div>
                                <div class="col-12 mt-4">
                                    <label class="text-muted small d-block mb-2">Địa chỉ cần giao</label>
                                    <div class="bg-white p-3 rounded-3 border">
                                        <p class="mb-0 text-dark" id="deliveryAddress" style="line-height: 1.6;"></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Lịch trình vận chuyển -->
                    <div id="deliveringAddressSection" class="card border-0 shadow-sm rounded-4 mb-4 d-none">
                        <div class="card-body p-4">
                            <h6 class="mb-3 d-flex align-items-center" style="color: #565c66;">
                                <i class="fa fa-truck-loading me-2" style="color: #505050;"></i> Lịch trình / Các trạm vận chuyển
                            </h6>
                            <div id="deliveringAddressList" class="mb-3"></div>
                            <div class="input-group" id="deliveringAddressInputGroup">
                                <input type="text" class="form-control border-end-0" id="newDeliveringAddress" placeholder="Nhập trạm vận chuyển mới...">
                                <button class="btn btn-primary px-4" type="button" id="btnAddDeliveringAddress">Thêm trạm</button>
                            </div>
                        </div>
                    </div>

                    <!-- Thông báo -->
                    <div class="row mb-3 notice-section">
                        <div class="col-md-12">
                            <label class="mb-2" style="color: #565c66;"><i class="fa fa-bell me-1" style="color: #505050;"></i> Nội dung thông báo tới khách hàng:</label>
                            <textarea class="form-control rounded-3" id="noticeContent" rows="3" placeholder="Nhập thông tin cập nhật cho khách hàng..."></textarea>
                            <div class="err-noticeContent text-danger small mt-1">Vui lòng nhập nội dung thông báo.</div>
                        </div>
                    </div>

                    <div class="row mb-3 d-none">
                        <div class="col-md-12">
                            <label class="mb-2">Phản hồi:</label>
                            <textarea class="form-control rounded-3" id="noteAnswered" rows="3"></textarea>
                            <div class="err-noteAnswered text-danger small mt-1">Vui lòng nhập nội dung phản hồi.</div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-main">Chỉnh sửa</button>
            </div>
        </div>
    </div>
   </div>
   <script src="/js/page-consignment.js"></script>
