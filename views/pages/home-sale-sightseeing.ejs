<div class="common-table-container row" id="page-home-sale-sightseeing">
      <div class="col-xl-12">
         <div class="row mb-3">
            <div class="col-12">
               <div class="card">
                  <div class="card-body">
                     <div class="d-flex justify-content-between">
                        <p class="title-page"><%= title %></p>
                     </div>
                  </div>
               </div>
            </div>
         </div>
         <div class="row">
            <div class="col-12">
               <div class="container-table">
                  <div class="table-responsive">
                     <table class="table table-striped">
                        <thead class="table-dark">
                           <tr class="text-center">
                              <th>
                                 <p>STT</p>
                              </th>
                              <th>
                                 <p>Nhà yến</p>
                              </th>
                              <th>
                                 <p>Tên khách hàng</p>
                              </th>
                              <th>
                                 <p>Số điện thoại</p>
                              </th>
                              <th>
                                 <p>Số lượng tham quan</p>
                              </th>
                              <th>
                                 <p>Trạng thái</p>
                              </th>
                              <th>
                                 <p>Ngày tạo</p>
                              </th>
                              <th>

                              </th>
                           </tr>
                        </thead>
                        <tbody class="body-table"></tbody>
                     </table>
                  </div>
                  <nav>
                     <ul class="pagination" id="privacy-main-pager"></ul>
                  </nav>
               </div>
            </div>
         </div>
      </div>
   </div>
   </div>
   <!-- modal update-->
   <div class="modal common-modal home-sightseeing-update-modal" tabindex="-1" role="dialog
      aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
         <div class="modal-content">
            <div class="modal-header">
               <p class="modal-header-title">Chi tiết đăng ký tham quan</p>
               <button type="button" class="close btn" data-bs-dismiss="modal" aria-label="Close">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                     <path d="M4.5 4.5L19.5 19.5" stroke="#212529" stroke-width="3" stroke-linecap="round" />
                     <path d="M19.5 4.5L4.5 19.5" stroke="#212529" stroke-width="3" stroke-linecap="round" />
                  </svg>
               </button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <input type="hidden" id="seq" value="">
                    
                    <!-- Thông tin nhà yến -->
                    <div class="card border-0 bg-light rounded-4 mb-4 overflow-hidden">
                        <div class="row g-0">
                            <div class="col-md-5">
                                <img src="" class="homeImage w-100 h-100 object-fit-cover" style="min-height: 250px;" />
                            </div>
                            <div class="col-md-7">
                                <div class="card-body p-4">
                                    <h5 class="homeName fw-bold mb-3" style="color: #565c66;"></h5>
                                    <div class="mb-4">
                                        <label class="text-muted small d-block mb-1">Số lượng khách đăng ký</label>
                                        <p class="numberAttend mb-0"></p>
                                    </div>
                                    <div class="mb-0">
                                        <label class="text-muted small d-block mb-1">Trạng thái xử lý yêu cầu</label>
                                        <select class="form-select form-select-md w-100" id="status"></select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin người đăng ký -->
                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                        <div class="card-body p-4">
                            <h6 class="mb-4" style="color: #565c66;"><i class="fa fa-id-card me-2" style="color: #505050;"></i>Thông tin người đăng ký tham quan</h6>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="text-muted small d-block mb-1">Tên khách hàng</label>
                                    <p class="userName mb-0"></p>
                                </div>
                                <div class="col-md-6">
                                    <label class="text-muted small d-block mb-1">Số điện thoại liên hệ</label>
                                    <p class="userPhone mb-0"></p>
                                </div>
                                <div class="col-12">
                                    <label class="text-muted small d-block mb-2">Ghi chú từ khách hàng</label>
                                    <div class="bg-light p-3 rounded-3 border-0">
                                        <p class="note mb-0 text-dark italic" style="line-height: 1.6;"></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
               <button type="button" class="btn-submit">Chỉnh sửa</button>
            </div>
         </div>
      </div>
   </div>
   <script src="/js/page-home-sale-sightseeing.js"></script>