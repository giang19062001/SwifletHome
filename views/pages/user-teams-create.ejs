<div class="page-user-teams-mutation">
    <div class="row">
        <div class="col-12">
            <div class="row mb-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <p class="title-page">
                                    <%= title %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <form id="team-create-form" novalidate>
                                <div class="row">
                                    <div class="col-lg-4">
                                        <div class="row">
                                            <div class="col-md-12 form-group mb-3">
                                                <label for="teamName" class="form-label">Tên nhóm công xưởng</label>
                                                <input type="text" class="form-control" id="teamName" name="teamName" />
                                                <div class="error-message" data-error="teamName"></div>
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="teamPhone" class="form-label">Số điện thoại</label>
                                                <input type="text" class="form-control" id="teamPhone" name="teamPhone" />
                                                <div class="error-message" data-error="teamPhone"></div>
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="teamAddress" class="form-label">Địa chỉ</label>
                                                <input type="text" class="form-control" id="teamAddress"
                                                    name="teamAddress" />
                                                <div class="error-message" data-error="teamAddress"></div>
                                            </div>


                                            <div class="col-md-12 form-group mb-3">
                                                <label for="provinceCodes" class="form-label">Tỉnh / Thành phố</label>
                                                <select class="form-select" id="provinceCodes" name="provinceCodes" multiple>
                                                    <option value="">-- Chọn tỉnh/thành --</option>
                                                    <% if (values?.provinces && values.provinces.length> 0) { %>
                                                        <% values.provinces.forEach(function(province) { %>
                                                            <option value="<%= province.provinceCode %>">
                                                                <%= province.provinceName %>
                                                            </option>
                                                        <% }) %>
                                                    <% } %>
                                                </select>
                                                <div class="error-message" data-error="provinceCodes"></div>
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="userTypeCode" class="form-label">Loại công xưởng</label>
                                                <select class="form-select" id="userTypeCode" name="userTypeCode">
                                                    <option value="">-- Chọn loại công xưởng --</option>
                                                    <% if (values?.userTypes && values.userTypes.length> 0) { %>
                                                        <% values.userTypes.forEach(function(utype) { %>
                                                            <option value="<%= utype.userTypeCode %>"  data-keyword="<%= utype.userTypeKeyWord %>">
                                                                <%= utype.userTypeName %>
                                                            </option>
                                                        <% }) %>
                                                    <% } %>
                                                </select>
                                                <div class="error-message" data-error="userTypeCode"></div>
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="userCode" class="form-label">người đại diện</label>
                                                <select class="form-select" id="userCode" name="userCode" disabled>
                                                    <option value="">-- Chọn người đại diện --</option>
                                                </select>
                                                <div class="error-message" data-error="userCode"></div>
                                            </div>

                                            <div id="factorySpecialFields" class="col-md-12 form-group mb-3 d-none">
                                                <div class="mb-3">
                                                    <label for="monthlyVolumn" class="form-label">Sản lượng trên 1 tháng</label>
                                                    <input type="number" class="form-control" id="monthlyVolumn" name="monthlyVolumn" placeholder="Nhập sản lượng..." />
                                                    <div class="error-message" data-error="monthlyVolumn"></div>
                                                </div>
                                                
                                                <div>
                                                    <label for="minimunQuantity" class="form-label">Số lượng tối thiểu</label>
                                                    <input type="number" class="form-control" id="minimunQuantity" name="minimunQuantity" placeholder="Nhập số lượng..." />
                                                    <div class="error-message" data-error="minimunQuantity"></div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                    <div class="col-lg-8">
                                        <div class="row">
                                            <div class="col-md-3 form-group">
                                                <label for="teamImage" class="form-label">Ảnh chính</label>
                                                <br />
                                                <label for="teamImage" class="file-label">
                                                    <span class="file-button">Chọn ảnh chính</span>
                                                </label>
                                                <input type="file" class="form-control d-none" id="teamImage" name="teamImage"
                                                    accept=".png, .jpg, .jpeg" />
                                                <div class="error-message mt-2" data-error="teamImage"></div>
                                                <div class="mt-3 mb-2 image-preview-container" id="teamImagePreview"></div>
                                            </div>

                                            <div class="col-md-9 form-group" id="dynamicFileTypesContainer">
                                                <label class="form-label">Ảnh/Video phụ theo loại</label>
                                                <div id="fileTypesList">
                                                    <% if (values?.teamFileTypes && values.teamFileTypes.length > 0) { %>
                                                        <% values.teamFileTypes.forEach(function(fileType) { %>
                                                            <div class="mb-3 img-type-block d-none" data-usertypecode="<%= fileType.userTypeCode %>">
                                                                <label for="teamFiles_<%= fileType.fileTypeCode %>" class="form-label fw-bold"><%= fileType.fileTypeText %></label>
                                                                <br />
                                                                <label for="teamFiles_<%= fileType.fileTypeCode %>" class="file-label">
                                                                    <span class="file-button">Chọn ảnh/video</span>
                                                                </label>
                                                                <input type="file" class="form-control dynamic-team-files" id="teamFiles_<%= fileType.fileTypeCode %>"
                                                                    name="teamFiles_<%= fileType.fileTypeCode %>" multiple accept=".png, .jpg, .jpeg, .mp4, .mov, .avi"
                                                                    data-typecode="<%= fileType.fileTypeCode %>" />
                                                                <div class="error-message mt-2" data-error="teamFiles_<%= fileType.fileTypeCode %>"></div>
                                                                <div class="image-preview-container" id="teamFilesPreview_<%= fileType.fileTypeCode %>"></div>
                                                            </div>
                                                        <% }) %>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <div class="row mt-2 last-box">
                                    <div class="col-lg-12 mb-3">
                                        <div class="d-flex gap-5 align-items-center mb-2">
                                            <label class="form-label m-0 d-none">Đăng ký dịch vụ</label>
                                            <button type="button" id="btnAddService">Thêm dịch vụ</button>
                                            
                                        </div>
                                        <div id="servicesContainer">
                                            <!-- Services dynamic inputs -->
                                        </div>
                                    </div>
                                    <div class="col-lg-12">
                                        <div class="form-group">
                                            <label for="teamDescription" class="form-label">Mô tả</label>
                                            <%- include('./component-editor', { content: "" }) %>
                                                <div class="error-message" data-error="teamDescription"></div>
                                        </div>
                                    </div>



                                    <div class="col-12 form-group d-flex justify-content-center mt-4">
                                        <button type="submit" class="btn-submit-lg">Thêm</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
  const teamFileTypes = <%- JSON.stringify(values.teamFileTypes) %>;
  const serviceOptionsFactory = <%- JSON.stringify(values.serviceOptionsFactory) %>;
  const serviceOptionsTechnical = <%- JSON.stringify(values.serviceOptionsTechnical) %>;
  console.log('teamFileTypes', teamFileTypes);
  console.log('serviceOptionsFactory', serviceOptionsFactory);
  console.log('serviceOptionsTechnical', serviceOptionsTechnical);
</script>

<script src="/js/common-validate.js"></script>
<script src="/js/page-user-teams-mutation.js"></script>