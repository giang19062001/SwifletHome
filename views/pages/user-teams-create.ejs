<div class="page-user-teams-mutation">
    <div class="row">
        <div class="col-12">
            <div class="row mb-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <p class="title-page">
                                    <%= title %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row g-4">
                <div class="col-12">
                    <form id="team-create-form" novalidate>
                        <div class="row g-4">
                            <!-- Section: Thông tin đại diện & Nhóm -->
                            <div class="col-lg-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-white py-3">
                                        <h6 class="mb-0 fw-bold card-title-custom">Thông tin nhóm & Đại diện</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="form-group mb-3">
                                            <label for="teamName" class="form-label small text-muted">Tên nhóm / Công xưởng</label>
                                            <input type="text" class="form-control" id="teamName" name="teamName" placeholder="Nhập tên nhóm..." />
                                            <div class="error-message" data-error="teamName"></div>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="teamUserName" class="form-label small text-muted">Tên người đại diện</label>
                                            <input type="text" class="form-control" id="teamUserName" name="teamUserName" placeholder="Họ và tên..." />
                                            <div class="error-message" data-error="teamUserName"></div>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="teamPhone" class="form-label small text-muted">Số điện thoại liên hệ</label>
                                            <input type="text" class="form-control" id="teamPhone" name="teamPhone" placeholder="090xxxxxxx" />
                                            <div class="error-message" data-error="teamPhone"></div>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="teamAddress" class="form-label small text-muted">Địa chỉ trụ sở</label>
                                            <input type="text" class="form-control" id="teamAddress" name="teamAddress" placeholder="Địa chỉ chi tiết..." />
                                            <div class="error-message" data-error="teamAddress"></div>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="provinceCodes" class="form-label small text-muted">Khu vực hoạt động (Tỉnh/Thành)</label>
                                            <select class="form-select" id="provinceCodes" name="provinceCodes" multiple>
                                                <option value="">-- Chọn tỉnh/thành --</option>
                                                <% if (values?.provinces && values.provinces.length> 0) { %>
                                                    <% values.provinces.forEach(function(province) { %>
                                                        <option value="<%= province.provinceCode %>">
                                                            <%= province.provinceName %>
                                                        </option>
                                                    <% }) %>
                                                <% } %>
                                            </select>
                                            <div class="error-message" data-error="provinceCodes"></div>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="userTypeCode" class="form-label small text-muted">Loại hình công xưởng</label>
                                            <select class="form-select" id="userTypeCode" name="userTypeCode">
                                                <option value="">-- Chọn loại hình --</option>
                                                <% if (values?.userTypes && values.userTypes.length> 0) { %>
                                                    <% values.userTypes.forEach(function(utype) { %>
                                                        <option value="<%= utype.userTypeCode %>" data-keyword="<%= utype.userTypeKeyWord %>">
                                                            <%= utype.userTypeName %>
                                                        </option>
                                                    <% }) %>
                                                <% } %>
                                            </select>
                                            <div class="error-message" data-error="userTypeCode"></div>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="userCode" class="form-label small text-muted">Tài khoản đại diện (Admin cấp)</label>
                                            <select class="form-select" id="userCode" name="userCode" disabled>
                                                <option value="">-- Chọn người đại diện --</option>
                                            </select>
                                            <div class="error-message" data-error="userCode"></div>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label class="form-label small text-muted">Chọn lọc</label>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="isSeleted" name="isSeleted" value="Y">
                                                <label class="form-check-label" for="isSeleted">Được chọn lọc</label>
                                            </div>
                                        </div>

                                        <div id="factorySpecialFields" class="bg-light p-3 rounded-3 d-none mt-3">
                                            <div class="mb-3">
                                                <label for="monthlyVolumn" class="form-label small text-muted">Sản lượng dự kiến (tháng)</label>
                                                <input type="number" class="form-control" id="monthlyVolumn" name="monthlyVolumn" placeholder="Nhập sản lượng..." />
                                                <div class="error-message" data-error="monthlyVolumn"></div>
                                            </div>
                                            
                                            <div class="mb-0">
                                                <label for="minimunQuantity" class="form-label small text-muted">Số lượng đơn tối thiểu</label>
                                                <input type="number" class="form-control" id="minimunQuantity" name="minimunQuantity" placeholder="Nhập số lượng..." />
                                                <div class="error-message" data-error="minimunQuantity"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Section: Hình ảnh & Hồ sơ năng lực -->
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-white py-3">
                                        <h6 class="mb-0 fw-bold card-title-custom">Hình ảnh & Hồ sơ năng lực</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="row g-4">
                                            <div class="col-md-4">
                                                <div class="upload-zone p-4 border-dashed rounded-4 text-center bg-light h-100">
                                                    <label class="form-label d-block fw-bold mb-3">Ảnh đại diện nhóm</label>
                                                    <label for="teamImage" class="btn btn-outline-primary btn-sm px-3 rounded-pill mb-2">
                                                        <i class="fa fa-camera me-2"></i>Chọn ảnh chính
                                                    </label>
                                                    <input type="file" class="d-none" id="teamImage" name="teamImage" accept=".png, .jpg, .jpeg" />
                                                    <div class="error-message mt-2" data-error="teamImage"></div>
                                                    <div class="mt-3 image-preview-container" id="teamImagePreview"></div>
                                                </div>
                                            </div>

                                            <div class="col-md-8" id="dynamicFileTypesContainer">
                                                <div class="bg-light p-4 rounded-4 h-100">
                                                    <label class="form-label d-block fw-bold mb-3 text-muted">Ảnh/Video chi tiết (theo loại hình)</label>
                                                    <div id="fileTypesList">
                                                        <% if (values?.teamFileTypes && values.teamFileTypes.length > 0) { %>
                                                            <% values.teamFileTypes.forEach(function(fileType) { %>
                                                                <div class="mb-4 img-type-block d-none p-3 bg-white rounded-3 shadow-sm" data-usertypecode="<%= fileType.userTypeCode %>">
                                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                                        <label class="form-label fw-bold mb-0 text-dark"><%= fileType.fileTypeText %></label>
                                                                        <label for="teamFiles_<%= fileType.fileTypeCode %>" class="btn btn-sm btn-link text-decoration-none p-0">
                                                                            <i class="fa fa-plus-circle me-1"></i>Chọn tệp
                                                                        </label>
                                                                    </div>
                                                                    <input type="file" class="form-control d-none dynamic-team-files" id="teamFiles_<%= fileType.fileTypeCode %>"
                                                                        name="teamFiles_<%= fileType.fileTypeCode %>" multiple accept=".png, .jpg, .jpeg, .mp4, .mov, .webm"
                                                                        data-typecode="<%= fileType.fileTypeCode %>" />
                                                                    <div class="error-message mt-1" data-error="teamFiles_<%= fileType.fileTypeCode %>"></div>
                                                                    <div class="image-preview-container mt-2" id="teamFilesPreview_<%= fileType.fileTypeCode %>"></div>
                                                                </div>
                                                            <% }) %>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Section: Dịch vụ & Mô tả -->
                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0 fw-bold card-title-custom">Dịch vụ cung cấp & Mô tả</h6>
                                        <button type="button" id="btnAddService" class="btn btn-sm btn-primary rounded-pill px-3">
                                            <i class="fa fa-plus me-1"></i>Thêm dịch vụ
                                        </button>
                                    </div>
                                    <div class="card-body">
                                        <div id="servicesContainer" class="row g-3 mb-4">
                                            <!-- Services dynamic inputs -->
                                        </div>

                                        <div class="form-group">
                                            <label for="teamDescription" class="form-label small text-muted">Mô tả nhóm</label>
                                            <%- include('./component-editor', { content: "" }) %>
                                            <div class="error-message mt-2" data-error="teamDescription"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Action Button -->
                            <div class="col-12 text-center mt-2">
                                <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill fw-bold btn-submit-lg">
                                    Xác nhận đăng ký thông tin
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
  const teamFileTypes = <%- JSON.stringify(values.teamFileTypes) %>;
  const teamServiceTypes = <%- JSON.stringify(values.teamServiceTypes) %>;
  console.log('teamFileTypes', teamFileTypes);
  console.log('teamServiceTypes', teamServiceTypes);
</script>

<script src="/js/common-validate.js"></script>
<script src="/js/page-user-teams-mutation.js"></script>