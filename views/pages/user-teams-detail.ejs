<div class="page-user-teams-mutation" id="page-user-teams-detail">
    <div class="row">
        <div class="col-12">
            <div class="row mb-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                 <p class="title-page"><%= title %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <form id="team-detail-form" novalidate>
                               <div class="row">
                                    <div class="col-lg-4">
                                        <div class="row">
                                            <div class="col-md-12 form-group mb-3">
                                                <label for="teamName" class="form-label">Tên nhóm công xưởng</label>
                                                <input type="text" class="form-control" id="teamName" name="teamName" readonly />
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="teamUserName" class="form-label">Tên người đại diện</label>
                                                <input type="text" class="form-control" id="teamUserName" name="teamUserName" readonly />
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="teamPhone" class="form-label">Số điện thoại</label>
                                                <input type="text" class="form-control" id="teamPhone" name="teamPhone" readonly />
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="teamAddress" class="form-label">Địa chỉ</label>
                                                <input type="text" class="form-control" id="teamAddress"
                                                    name="teamAddress" readonly />
                                            </div>


                                            <div class="col-md-12 form-group mb-3">
                                                <label for="provinceCodes" class="form-label">Tỉnh / Thành phố</label>
                                                <select class="form-select" id="provinceCodes" name="provinceCodes" multiple disabled>
                                                    <option value="">-- Chọn tỉnh/thành --</option>
                                                    <% if (values?.provinces && values.provinces.length> 0) { %>
                                                        <% values.provinces.forEach(function(province) { %>
                                                            <option value="<%= province.provinceCode %>">
                                                                <%= province.provinceName %>
                                                            </option>
                                                        <% }) %>
                                                    <% } %>
                                                </select>
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="userTypeCode" class="form-label">Loại công xưởng</label>
                                                <select class="form-select" id="userTypeCode" name="userTypeCode" disabled>
                                                    <option value="">-- Chọn loại công xưởng --</option>
                                                    <% if (values?.userTypes && values.userTypes.length> 0) { %>
                                                        <% values.userTypes.forEach(function(utype) { %>
                                                            <option value="<%= utype.userTypeCode %>"
                                                                data-keyword="<%= utype.userTypeKeyWord %>">
                                                                <%= utype.userTypeName %>
                                                            </option>
                                                        <% }) %>
                                                    <% } %>
                                                </select>
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label for="userCode" class="form-label">người đại diện</label>
                                                <select class="form-select" id="userCode" name="userCode" disabled>
                                                    <option value="">-- Chọn người đại diện --</option>
                                                </select>
                                            </div>

                                            <div class="col-md-12 form-group mb-3">
                                                <label class="form-label">Chọn lọc</label>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="isSeleted" name="isSeleted" value="Y" disabled>
                                                    <label class="form-check-label" for="isSeleted">Được chọn lọc</label>
                                                </div>
                                            </div>

                                            <div id="factorySpecialFields" class="col-md-12 form-group mb-3 d-none">
                                                <div class="mb-3">
                                                    <label for="monthlyVolumn" class="form-label">Sản lượng trên 1 tháng</label>
                                                    <input type="number" class="form-control" id="monthlyVolumn" name="monthlyVolumn" readonly />
                                                </div>
                                                
                                                <div>
                                                    <label for="minimunQuantity" class="form-label">Số lượng tối thiểu</label>
                                                    <input type="number" class="form-control" id="minimunQuantity" name="minimunQuantity" readonly />
                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                    <div class="col-lg-8">
                                        <div class="row">
                                            <div class="col-md-3 form-group">
                                                <label for="teamImage" class="form-label">Ảnh chính</label>
                                                <div class="mt-3 mb-2 image-preview-container" id="teamImagePreview"></div>
                                            </div>

                                            <div class="col-md-9 form-group" id="dynamicFileTypesContainer">
                                                <label class="form-label">Ảnh/Video phụ theo loại</label>
                                                
                                                <div id="fileTypesList">
                                                    <% if (values?.teamFileTypes && values.teamFileTypes.length > 0) { %>
                                                        <% values.teamFileTypes.forEach(function(fileType) { %>
                                                            <div class="mb-3 img-type-block d-none" data-usertypecode="<%= fileType.userTypeCode %>">
                                                                <label class="form-label"><%= fileType.fileTypeText %></label>
                                                                <div class="image-preview-container" id="teamFilesPreview_<%= fileType.fileTypeCode %>"></div>
                                                            </div>
                                                        <% }) %>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <div class="row mt-2 last-box">
                                    <div class="col-lg-12 mb-3">
                                        <div class="d-flex gap-5 align-items-center mb-2">
                                            <label class="form-label m-0">Danh sách dịch vụ đăng ký</label>
                                        </div>
                                        <div id="servicesContainer">
                                            <!-- Services dynamic inputs -->
                                        </div>
                                    </div>
                                    <div class="col-lg-12">
                                        <div class="form-group">
                                            <label for="teamDescription" class="form-label">Mô tả</label>
                                            <%- include('./component-editor', { content: "" }) %>
                                        </div>
                                    </div>

                                    <div class="col-12 form-group d-flex justify-content-center gap-3 mt-4">
                                        <% if (values?.teamData?.status === 'WAITING') { %>
                                            <button type="button" class="btn btn-main px-5" onclick="updateTeamStatus(VARIABLE_ENUM.TEAM_STATUS.APPROVE.VALUE)">Duyệt</button>
                                            <!-- <button type="button" class="btn btn-danger px-5" onclick="updateTeamStatus(VARIABLE_ENUM.TEAM_STATUS.REFUSE.VALUE)">Từ chối</button> -->
                                        <% } %>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
  const teamFileTypes = <%- JSON.stringify(values.teamFileTypes) %>;
  const teamServiceTypes = <%- JSON.stringify(values.teamServiceTypes) %>;
  const teamData = <%- JSON.stringify(values.teamData) %>;
  const IS_DETAIL = true;
</script>
<script src="/js/common-validate.js"></script>
<script src="/js/page-user-teams-mutation.js"></script>
